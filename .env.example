# ---- Frontend (VITE_-prefixed → BAKED INTO THE PUBLIC BUNDLE; never put a real server secret here) ----
VITE_SUPABASE_URL=your_supabase_url_here
# Publishable key (sb_publishable_...) — replaces the legacy anon JWT. Safe in the browser; respects RLS.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
# Shared demo/sandbox account password. PUBLIC by design (VITE_ → in the bundle); rotating only retires the old string. See §1.9 for the real fix.
VITE_DEMO_PASSWORD=your_demo_password_here

# ---- Server-only (Node scripts / Vercel functions; NEVER VITE_-prefixed, NEVER in the browser) ----
# Secret key (sb_secret_...) — replaces the legacy service_role JWT. BYPASSRLS; server-only (Supabase 401s it in a browser).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# App base URL
APP_URL=https://app.coresite.io
